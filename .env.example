# ──────────────────────────────────────────────────────────────
#  PerGo — Variáveis de ambiente
#  Copie este arquivo: cp .env.example .env
#  Edite os valores necessários e carregue antes de rodar:
#    source .env && go run ./cmd/pergo
# ──────────────────────────────────────────────────────────────

# ------------------------------------
# PostgreSQL
# ------------------------------------
# URL de conexão com o banco de dados.
# Padrão docker-compose: porta 5432 (dentro do compose) ou 5433 (host).
PERGO_DATABASE_URL=postgres://postgres:postgres@localhost:5433/pergo?sslmode=disable

# ------------------------------------
# NATS / JetStream
# ------------------------------------
PERGO_NATS_URL=nats://localhost:4222

# ------------------------------------
# HTTP Server
# ------------------------------------
PERGO_SERVER_PORT=8080

# ------------------------------------
# Debug Server (pprof + expvar)
# Disponível em http://localhost:6060/debug/pprof/
# ------------------------------------
PERGO_DEBUG_PORT=6060

# ------------------------------------
# Admin Panel
# Senha para login em /admin
# ------------------------------------
PERGO_ADMIN_PASSWORD=troque-esta-senha

# ------------------------------------
# Criptografia (AES-256-GCM)
# Gere uma chave de 32 bytes em base64:
#   openssl rand -base64 32
# OBRIGATÓRIO em produção. Em dev, o servidor usa uma chave padrão insegura.
# ------------------------------------
PERGO_KEK_BASE64=

# ------------------------------------
# URL externa (necessária para media proxy)
# Usada para montar URLs absolutas de mídia enviadas via WABA.
# Em produção: URL pública do servidor (ex: https://api.suaempresa.com)
# ------------------------------------
PERGO_EXTERNAL_URL=http://localhost:8080

# ------------------------------------
# S3 / MinIO (armazenamento de mídia)
# Necessário apenas para enviar mensagens com mídia (imagens, documentos, áudio).
# Deixe em branco para desabilitar uploads de mídia.
# ------------------------------------
PERGO_S3_ENDPOINT=
PERGO_S3_BUCKET=
PERGO_S3_ACCESS_KEY=
PERGO_S3_SECRET_KEY=
PERGO_S3_REGION=us-east-1
# Use "true" para MinIO ou S3-compatível (path-style URLs)
PERGO_S3_USE_PATH_STYLE=false
